# Telegram Configuration
# 1. Message @BotFather on Telegram, send /newbot
# 2. Follow prompts to create bot, save the token
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Channel ID
# - For public channels: @your_channel_name
# - For private: Add @userinfobot to channel, it will tell you the numeric ID
TELEGRAM_CHANNEL_ID=@your_channel_name

# Optional: Custom database path (default: snipe.db)
# DB_PATH=snipe.db
